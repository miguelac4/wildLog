<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # ============================================
  # HTTPS & WWW REDIRECT (Global)
  # ============================================
  
  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # Remove www
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]
  
  # ============================================
  # WILDLOG ROUTES (rh360.pt/wildlog)
  # ============================================
  
  RewriteCond %{HTTP_HOST} ^(www\.)?rh360\.pt$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/wildlog/
  RewriteRule ^(.*)$ /wildlog/index.html [QSA,L]
  
  # ============================================
  # ROOT ROUTES (wild-log.com na raiz)
  # ============================================
  
  RewriteCond %{HTTP_HOST} ^(www\.)?wild-log\.com$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/index\.html$
  RewriteRule ^(.*)$ /index.html [QSA,L]
</IfModule>

# ============================================
# SECURITY & PERFORMANCE
# ============================================

# Compressão gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/x-font-ttf
  AddOutputFilterByType DEFLATE font/opentype
</IfModule>

# Cache control para assets estáticos
<IfModule mod_expires.c>
  ExpiresActive On

  # Imagens
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"

  # CSS
  ExpiresByType text/css "access plus 1 month"

  # JavaScript
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"

  # Vídeos
  ExpiresByType video/mp4 "access plus 1 month"
  ExpiresByType video/mpeg "access plus 1 month"
  ExpiresByType video/ogg "access plus 1 month"
  ExpiresByType video/webm "access plus 1 month"

  # Fonts
  ExpiresByType font/opentype "access plus 1 month"
  ExpiresByType application/x-font-ttf "access plus 1 month"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 month"

  # HTML - não cache
  ExpiresByType text/html "access plus 0 seconds"

  # Default
  ExpiresDefault "access plus 0 seconds"
</IfModule>

# Desabilita ETags para evitar conflicts em múltiplos servidores
<IfModule mod_headers.c>
  Header unset ETag
  FileETag None

  # Força revalidação para HTML
  Header set Cache-Control "max-age=0, must-revalidate"
</IfModule>

